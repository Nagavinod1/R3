{
  "name": "hospital-blood-management-system",
  "version": "1.0.0",
  "description": "Blockchain Enabled Intelligent Hospital Bed and Blood Resource Management System",
  "main": "server/index.js",
  "scripts": {
    "server": "nodemon server/index.js",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:all": "concurrently \"npm run server\" \"npm run client\" \"npm run ai-service\"",
    "install-all": "npm install && cd client && npm install && cd ../blockchain && npm install",
    "blockchain": "cd blockchain && npx hardhat node",
    "deploy-contracts": "cd blockchain && npx hardhat run scripts/deploy.js --network localhost",
    "ai-service": "cd ai-service && python app.py",
    "seed": "node server/utils/seedAdmin.js",
    "build": "cd client && npm run build"
  },
  "keywords": [
    "hospital",
    "blood-bank",
    "blockchain",
    "mern",
    "healthcare"
  ],
  "author": "Healthcare System",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.6.1",
    "web3": "^4.3.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.2"
  }
}
